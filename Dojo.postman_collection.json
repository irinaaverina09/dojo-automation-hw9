        {
          "name": "Create Products",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function randomString(len) {",
                  "  return Math.random().toString(36).substring(2, 2+len);",
                  "}",
                  "pm.collectionVariables.set(\"title\", \"Product_\" + randomString(5));",
                  "pm.collectionVariables.set(\"price\", Math.floor(Math.random()*1000)+1);",
                  "pm.collectionVariables.set(\"description\", \"Auto description\");",
                  "pm.collectionVariables.set(\"categoryId\", 1);",
                  "pm.collectionVariables.set(\"images\", [\"https://placehold.co/600x400\"]);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set(\"productId\", json.id);",
                  "pm.expect(json).to.have.property(\"id\");",
                  "pm.expect(json).to.have.property(\"title\");",
                  "pm.expect(json).to.have.property(\"price\");"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\r\n    \"title\": \"{{title}}\",\r\n    \"price\": {{price}},\r\n    \"description\": \"{{description}}\",\r\n    \"categoryId\": {{categoryId}},\r\n    \"images\": [\r\n        \"https://placehold.co/600x400\"\r\n    ]\r\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            }
          },
          "response": []
