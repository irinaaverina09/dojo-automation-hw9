        {
          "name": "Create User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "function randomString(len) {",
                  "  return Math.random().toString(36).substring(2, 2+len);",
                  "}",
                  "pm.collectionVariables.set(\"name\", \"User_\" + randomString(5));",
                  "pm.collectionVariables.set(\"email\", randomString(5) + \"@test.com\");",
                  "pm.collectionVariables.set(\"password\", randomString(8));",
                  "pm.collectionVariables.set(\"role\", Math.random() > 0.5 ? \"customer\" : \"admin\");",
                  "pm.collectionVariables.set(\"avatar\", \"https://picsum.photos/200\");"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set(\"userId\", json.id);",
                  "",
                  "pm.test(\"User schema is valid\", function () {",
                  "  pm.expect(json).to.have.property(\"id\");",
                  "  pm.expect(json).to.have.property(\"name\");",
                  "  pm.expect(json).to.have.property(\"role\");",
                  "  pm.expect(json).to.have.property(\"email\");",
                  "  pm.expect(json).to.have.property(\"password\");",
                  "  pm.expect(json).to.have.property(\"avatar\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{name}}\",\n  \"email\": \"{{email}}\",\n  \"password\": \"{{password}}\",\n  \"role\": \"{{role}}\",\n  \"avatar\": \"{{avatar}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Get Created User",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Ensure userId exists, otherwise run Create User first",
                  "if (!pm.collectionVariables.get(\"userId\")) {",
                  "  postman.setNextRequest(\"Create User\");",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "const json = pm.response.json();",
                  "pm.test(\"User schema is valid\", function () {",
                  "  pm.expect(json).to.have.property(\"id\");",
                  "  pm.expect(json).to.have.property(\"name\");",
                  "  pm.expect(json).to.have.property(\"role\");",
                  "  pm.expect(json).to.have.property(\"email\");",
                  "  pm.expect(json).to.have.property(\"password\");",
                  "  pm.expect(json).to.have.property(\"avatar\");",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
